isabled={otpTimer > 0}\n                                        className=\"flex items-center gap-1.5 text-blue-600 hover:text-blue-700 disabled:text-slate-400 disabled:cursor-not-allowed font-medium transition-colors\">\n                                        <RefreshCw className=\"w-3.5 h-3.5\" />\n                                        {otpTimer > 0 ? `Resend in ${otpTimer}s` : 'Resend OTP'}\n                                    </button>\n                                    <button type=\"button\" onClick={() => { setView('otp-email'); setOtp(''); setError(''); setSuccess(''); }}\n                                        className=\"text-slate-400 hover:text-slate-600 text-[13px]\">\n                                        Change email\n                                    </button>\n                                </div>\n                            </form>\n                        </div>\n                    </div>\n                )}\n            </div>\n        </>\n    );\n};\nexport default Login;\n","usedDeprecatedRules":[]},{"filePath":"/home/vixx/Documents/JobPortal/JobPortal/client/src/pages/ManageApplicants.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/home/vixx/Documents/JobPortal/JobPortal/client/src/pages/MockTestsList.jsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/home/vixx/Documents/JobPortal/JobPortal/client/src/pages/MyApplications.jsx","messages":[{"ruleId":"no-unused-vars","severity":2,"message":"'user' is assigned a value but never used. Allowed unused vars must match /^[A-Z_]/u.","line":7,"column":13,"nodeType":"Identifier","messageId":"unusedVar","endLine":7,"endColumn":17,"suggestions":[{"messageId":"removeVar","data":{"varName":"user"},"fix":{"range":[300,327],"text":""},"de